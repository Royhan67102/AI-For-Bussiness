    {
      "parameters": {
        "jsCode": "const formData = $('Formulir Pengajuan Cuti').first().json;\n\nconst currentRequestId =\n$('Validasi Cuti').first().json.requestId;\n\nconst startDate = new Date(formData[\"Tanggal Mulai\"]);\nconst endDate = new Date(formData[\"Tanggal Selesai\"]);\n\nconst existing = items;\n\nlet count = 0;\n\nfor (const item of existing) {\n\n  const data = item.json;\n\n  // skip request sendiri\n  if (data.ID_Request === currentRequestId) {\n    continue;\n  }\n\n  // hanya hitung pending + approved\n  if (\n    data.Status !== \"Approved\" &&\n    data.Status !== \"Rejected\"\n  ) {\n    continue;\n  }\n\n  if (!data.Tanggal_Mulai || !data.Tanggal_Selesai) {\n    continue;\n  }\n\n  const existingStart = new Date(data.Tanggal_Mulai);\n  const existingEnd = new Date(data.Tanggal_Selesai);\n\n  const overlap =\n    existingStart <= endDate &&\n    existingEnd >= startDate;\n\n  if (overlap) {\n    count++;\n  }\n}\n\nconst maxQuota = 2;\n\nconsole.log(\"Jumlah cuti overlap:\", count);\n\nreturn [{\n  json: {\n    ...formData,\n    cutiCount: count,\n    isFull: count >= maxQuota\n  }\n}];"
      },
