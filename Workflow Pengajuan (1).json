    {
      "parameters": {
        "jsCode": "// 1. Ambil Data Karyawan dari Google Sheets\nconst employeeData = items[0].json;\n\n// 2. Ambil Data Form Pengajuan\nconst formData = $('Formulir Pengajuan Cuti').first().json;\n\n// ======================\n// DAFTAR HARI LIBUR\n// ======================\n\nconst holidays = [\n  \"2026-01-01\",\n  \"2026-03-19\",\n  \"2026-03-20\",\n  \"2026-05-01\",\n  \"2026-05-14\",\n  \"2026-05-15\",\n  \"2026-12-25\"\n];\n\n// ======================\n// AMBIL TANGGAL CUTI\n// ======================\n\nconst start = DateTime.fromISO(formData[\"Tanggal Mulai\"]);\nconst end = DateTime.fromISO(formData[\"Tanggal Selesai\"]);\n\n// ======================\n// HITUNG HARI KERJA\n// ======================\n\nlet current = start;\nlet workingDays = 0;\n\nwhile (current <= end) {\n\n  const weekday = current.weekday;\n\n  // 6 = Sabtu\n  // 7 = Minggu\n\n  const currentDate = current.toISODate();\n\n  const isWeekend =\n    weekday === 6 || weekday === 7;\n\n  const isHoliday =\n    holidays.includes(currentDate);\n\n  // Hitung hanya hari kerja\n  if (!isWeekend && !isHoliday) {\n    workingDays++;\n  }\n\n  // Pindah ke hari berikutnya\n  current = current.plus({ days: 1 });\n}\n\n// ======================\n// VALIDASI SALDO CUTI\n// ======================\n\nconst currentBalance =\n  parseInt(employeeData[\"Saldo_Cuti\"]);\n\nconst hasEnoughBalance =\n  currentBalance >= workingDays;\n\n// ======================\n// GENERATE ID REQUEST\n// ======================\n\nconst uniqueId =\n  'REQ-' + Date.now();\n\n// ======================\n// OUTPUT\n// ======================\n\nreturn [\n  {\n    json: {\n      ...employeeData,\n      ...formData,\n\n      durationRequested: workingDays,\n\n      isApprovedSystem: hasEnoughBalance,\n\n      message: hasEnoughBalance\n        ? \"Saldo Cukup\"\n        : \"Saldo Tidak Cukup\",\n\n      requestId: uniqueId\n    }\n  }\n];"
      },
